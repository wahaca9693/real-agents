# Email Service Configuration
# Choose one of the following options:

# Option 1: Resend (Recommended - Free 100 emails/month)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_123456789

# Option 2: Mailgun (Free 5,000 emails/month)
# Get your API key from: https://mailgun.com
MAILGUN_API_KEY=key-placeholder
MAILGUN_DOMAIN=sandbox-placeholder.mailgun.org

# Option 3: SendGrid (Free 100 emails/day)
# Get your API key from: https://sendgrid.com
SENDGRID_API_KEY=SG.placeholder

# Option 4: Brevo (Free 300 emails/day)
# Get your API key from: https://www.brevo.com
BREVO_API_KEY=placeholder

# SMTP Configuration (Gmail/Outlook/Yahoo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Real Agents

# Fallback for testing
TEST_EMAIL=2015qpwpeprp@gmail.com
